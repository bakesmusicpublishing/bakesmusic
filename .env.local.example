# ============================================================
# bakesmusic.com — Environment Variables
# Copy this to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================

# Google AdSense
# Get from: https://www.google.com/adsense → My ads → Publisher ID
# Format: ca-pub-XXXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-XXXXXXXXXXXXXXXXX

# Google Analytics (optional but recommended)
# Get from: https://analytics.google.com → Admin → Data Streams
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Site URL (used for canonical links etc)
NEXT_PUBLIC_SITE_URL=https://bakesmusic.com
